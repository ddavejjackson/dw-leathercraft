---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Dustworn Leathercrafts";
---
<BaseLayout pageTitle={pageTitle}>
	<section class="max-w-3xl mx-auto text-center space-y-6">
		<h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-yellow-500">
    	  Dustworn isn't just a brand. It's a philosophy.
    	</h2>
		<p class="text-gray-300 text-lg leading-relaxed">
			Wear is beauty. Time is the collaborator. Story is the goal.
		</p>
	</section>
	<section class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

    <div class="p-6 border border-yellow-600/20 rounded-lg bg-neutral-900/40">
        <h3 class="text-xl font-semibold text-yellow-500 mb-2">Craft</h3>
        <p class="text-gray-400">
          Each piece is shaped by hand and built to endure the years that follow.
        </p>
    </div>

    <div class="p-6 border border-yellow-600/20 rounded-lg bg-neutral-900/40">
        <h3 class="text-xl font-semibold text-yellow-500 mb-2">Patina</h3>
        <p class="text-gray-400">
          True beauty emerges through use, wear, and the quiet passage of time.
        </p>
    </div>

    <div class="p-6 border border-yellow-600/20 rounded-lg bg-neutral-900/40">
        <h3 class="text-xl font-semibold text-yellow-500 mb-2">Story</h3>
          <p class="text-gray-400">
            Every mark and crease becomes part of the story carried with you.
          </p>
    </div>
  </section>
</BaseLayout>