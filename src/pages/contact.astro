---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Contact Us";
---

<BaseLayout pageTitle={pageTitle}>
    <div class="max-w-xl mx-auto text-center space-y-6">
        <p class="text-lg text-gray-300">Have a question or query about an order?</p>
        <p class="text-gray-400">Feel free to contact us on instagram or send us an email.</p>
        <div class="flex flex-col sm:flex-row.justify-center gap-4 pt-4">
            <a
                href="https://instagram.com/leathercraft_customs"
                target="_blank"
                rel="noopener noreferrer"
                class="px-6 py-3 rounded-md border border-yellow-500 text-yellow-500 font-semibold
                       hover:bg-yellow-500 hover:text-black transition shadow-md hover:shadow-lg"
              >
                Contact on Instagram
              </a>
            <a
                href="mailto:leathercraft_customs@yahoo.com"
                class="px-6 py-3 rounded-md border border-yellow-500 text-yellow-500 font-semibold
                       hover:bg-yellow-500 hover:text-black transition shadow-md hover:shadow-lg"
              >
                Send Email
              </a>
        </div>
    </div>
</BaseLayout>