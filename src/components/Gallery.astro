---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const images = Object.values(
  import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/gallery/*.{jpg,jpeg,png}",
    { eager: true }
  )
);

const batchSize = 20;
---

<div
  id="gallery"
  class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4"
>
  {images.map((img, i) => (
    <div
      class:list={[
        "gallery-item group relative aspect-square overflow-hidden rounded-lg",
        "opacity-0 transition-opacity duration-500",
        i < batchSize && "opacity-100"
      ]}
    >

      <Image
        src={img.default}
        alt=""
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
        sizes="(max-width:640px) 50vw,
               (max-width:768px) 33vw,
               (max-width:1024px) 25vw,
               20vw"
      />

      <!-- subtle gold overlay on hover -->
      <div class="absolute inset-0 bg-yellow-500/0 group-hover:bg-yellow-500/10 transition-colors duration-500"></div>

    </div>
  ))}

  <div id="sentinel" class="col-span-full h-1"></div>
</div>

<script define:vars={{ batchSize }}>
  const items = document.querySelectorAll(".gallery-item");
  const sentinel = document.getElementById("sentinel");

  let visible = batchSize;

  function revealNextBatch() {
    for (let i = visible; i < visible + batchSize; i++) {
      if (items[i]) {
        items[i].classList.remove("opacity-0");
        items[i].classList.add("opacity-100");
      }
    }

    visible += batchSize;

    if (visible >= items.length) {
      observer.disconnect();
    }
  }

  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      revealNextBatch();
    }
  }, {
    rootMargin: "200px"
  });

  observer.observe(sentinel);
</script>