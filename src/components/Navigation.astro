---
import "../styles/global.css";

const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/values/", label: "Values" },
  { href: "/contact/", label: "Contact" },
  { href: "/gallery/", label: "Gallery" }
];
---

<nav class="bg-black border-b border-yellow-600/20">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">

      <!-- Logo -->
      <div class="text-xl font-semibold text-yellow-500">
        Dustworn Leathercrafts
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-6">

        {links.map((link) => {
          const isActive = currentPath === link.href;

          return (
            <a
              href={link.href}
              class="group relative px-3 py-2 rounded-md font-medium
                     text-yellow-500 transition
                     hover:bg-yellow-500 hover:text-black"
            >
              {link.label}

              <!-- animated underline -->
              <span
                class:list={[
                  "absolute left-1/2 -bottom-1 h-[2px] bg-yellow-500 transition-all duration-300",
                  "group-hover:w-full group-hover:left-0",
                  isActive ? "w-full left-0" : "w-0"
                ]}
              ></span>
            </a>
          );
        })}

      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <button
          id="menu-btn"
          class="text-yellow-500 focus:outline-none"
          aria-label="Toggle menu"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor"
               viewBox="0 0 24 24">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden max-h-0 overflow-hidden opacity-0
           transition-all duration-300 ease-in-out
           px-4 space-y-2 text-center"
  >

    {links.map((link) => {
      const isActive = currentPath === link.href;

      return (
        <a
          href={link.href}
          class:list={[
            "block px-3 py-2 rounded-md font-medium transition",
            "hover:bg-yellow-500 hover:text-black active:bg-yellow-500 active:text-black",
            isActive
              ? "bg-yellow-500 text-black underline underline-offset-4"
              : "text-yellow-500"
          ]}
        >
          {link.label}
        </a>
      );
    })}
  </div>
</nav>