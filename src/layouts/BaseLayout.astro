---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
const { pageTitle } = Astro.props;
---
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-black text-gray-200 antialiased">
    <div class="min-h-screen flex flex-col">
      <Header />
      <section class="px-6 sm:px-8 lg:px-12 py-12 sm:py-16 text-center border-b border-yellow-600/20">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold 
                   text-yellow-500 tracking-wide">
          {pageTitle}
        </h1>
        <div class="mt-4 h-1 w-20 mx-auto bg-yellow-500 rounded-full"></div>
      </section>
      <main class="flex-1 w-full max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-10">
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>